{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.socioprophet.org/gitea-sovereign/token.schema.json",
  "title": "ScopedAgentToken",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "token_id",
    "session_id",
    "agent_id",
    "issuer_node",
    "aud",
    "issued_at",
    "not_before",
    "expires_at",
    "scope",
    "intent_hash",
    "policy_decision_ref",
    "grant_ref",
    "device_hash",
    "replay_nonce",
    "key_id",
    "alg",
    "signature"
  ],
  "properties": {
    "token_id": { "type": "string", "format": "uuid" },
    "session_id": { "type": "string", "format": "uuid" },
    "agent_id": { "type": "string", "format": "uuid" },
    "issuer_node": { "type": "string", "minLength": 1 },
    "aud": { "type": "string", "const": "gitea-sovereign" },
    "issued_at": { "type": "integer", "minimum": 0 },
    "not_before": { "type": "integer", "minimum": 0 },
    "expires_at": { "type": "integer", "minimum": 0 },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repos", "branches", "ops"],
      "properties": {
        "repos": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "branches": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "ops": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["read", "commit", "push", "branch-create", "branch-delete", "pr-open", "pr-merge", "tag"]
          }
        },
        "paths_allow": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "paths_deny": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 }, "default": [".env", "**/*secret*", "**/*credential*", ".venv/**", "node_modules/**", "dist/**"] }
      }
    },
    "intent_hash": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "policy_decision_ref": { "type": "string", "minLength": 1 },
    "grant_ref": { "type": "string", "minLength": 1 },
    "device_hash": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "replay_nonce": { "type": "string", "minLength": 16 },
    "cross_node": { "type": "boolean", "default": false },
    "key_id": { "type": "string", "minLength": 1 },
    "alg": { "type": "string", "enum": ["HS256", "Ed25519"] },
    "signature": { "type": "string", "minLength": 16 }
  }
}
