{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.socioprophet.org/gitea-sovereign/agent-registration.schema.json",
  "title": "AgentRegistrationCache",
  "description": "Bootstrap cache only. Canonical authority: SocioProphet/agent-registry.",
  "type": "object",
  "additionalProperties": false,
  "required": ["agent_id", "name", "type", "registered_at", "scope_template", "status", "canonical_ref"],
  "properties": {
    "agent_id": { "type": "string", "format": "uuid" },
    "name": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "enum": ["external", "gitea-native", "mesh-node"] },
    "registered_at": { "type": "integer", "minimum": 0 },
    "canonical_ref": { "type": "string", "minLength": 1 },
    "scope_template": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repos": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "branches": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "ops": { "type": "array", "uniqueItems": true, "items": { "type": "string", "enum": ["read", "commit", "push", "branch-create", "branch-delete", "pr-open", "pr-merge", "tag"] } },
        "paths_allow": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "paths_deny": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "max_token_ttl_seconds": { "type": "integer", "minimum": 1, "maximum": 900, "default": 900 }
      }
    },
    "ltlf_contract_ref": { "type": "string", "minLength": 1 },
    "reputation_score": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.5 },
    "status": { "type": "string", "enum": ["active", "suspended", "revoked"] }
  }
}
