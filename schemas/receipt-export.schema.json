{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.socioprophet.org/gitea-sovereign/receipt-export.schema.json",
  "title": "ReceiptExportBatch",
  "type": "object",
  "additionalProperties": false,
  "required": ["export_batch_id", "node_id", "first_seq", "last_seq", "batch_hash", "destination_ref", "exported_at", "ack_required"],
  "properties": {
    "export_batch_id": { "type": "string", "format": "uuid" },
    "node_id": { "type": "string", "minLength": 1 },
    "first_seq": { "type": "integer", "minimum": 0 },
    "last_seq": { "type": "integer", "minimum": 0 },
    "batch_hash": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "destination_ref": { "type": "string", "minLength": 1 },
    "exported_at": { "type": "string", "format": "date-time" },
    "ack_required": { "type": "boolean", "const": true },
    "ack_hash": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "ack_received_at": { "type": "string", "format": "date-time" }
  }
}
