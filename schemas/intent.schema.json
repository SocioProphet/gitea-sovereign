{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.socioprophet.org/gitea-sovereign/intent.schema.json",
  "title": "AgentIntent",
  "type": "object",
  "additionalProperties": false,
  "required": ["intent_id", "agent_id", "session_id", "registered_at", "operations", "policy_decision_ref"],
  "properties": {
    "intent_id": { "type": "string", "format": "uuid" },
    "agent_id": { "type": "string", "format": "uuid" },
    "session_id": { "type": "string", "format": "uuid" },
    "registered_at": { "type": "integer", "minimum": 0 },
    "policy_decision_ref": { "type": "string", "minLength": 1 },
    "grant_ref": { "type": "string", "minLength": 1 },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["op", "repo", "branch", "base_ref", "operation_order"],
        "properties": {
          "op": { "type": "string", "enum": ["read", "commit", "push", "branch-create", "branch-delete", "pr-open", "pr-merge", "tag"] },
          "repo": { "type": "string", "minLength": 1 },
          "branch": { "type": "string", "minLength": 1 },
          "base_ref": { "type": "string", "minLength": 1 },
          "expected_head": { "type": "string", "minLength": 1 },
          "pr_target": { "type": "string", "minLength": 1 },
          "paths_allow": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "paths_deny": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "branch_protection": { "type": "string", "enum": ["none", "require-pr", "require-review", "locked"] },
          "operation_order": { "type": "integer", "minimum": 0 },
          "description": { "type": "string" },
          "evidence_output_path": { "type": "string", "minLength": 1 }
        }
      }
    },
    "user_approved": { "type": "boolean" },
    "approved_at": { "type": "integer", "minimum": 0 },
    "replay_allowed": { "type": "boolean", "default": false }
  }
}
